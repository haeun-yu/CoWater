# Device Registration Server - Configuration Template
# Copy this file to .env or .env.local and customize values

# ============ Server Configuration ============
SERVER_HOST=0.0.0.0
SERVER_PORT=9100
SECRET_KEY=server-secret-change-in-production

# ============ Healthcheck & Health Check ============
# Interval at which agents should send healthchecks (seconds)
HEALTHCHECK_INTERVAL_SECONDS=10
# Timeout threshold - device marked offline if no healthcheck in this time (seconds)
HEALTHCHECK_TIMEOUT_SECONDS=30

# ============ Dynamic Re-binding Configuration ============
# Minimum distance improvement (meters) required to trigger parent re-assignment
# Set to 500m: only re-bind if new parent is 500m+ closer
# Set to 0 to re-bind to any closer parent
REBINDING_DISTANCE_DELTA_THRESHOLD_METERS=500

# How frequently the server checks for re-binding opportunities (seconds)
# Set to 1 for real-time, higher values reduce CPU usage
REBINDING_CHECK_INTERVAL_SECONDS=1

# ============ Moth Integration ============
# Moth WebSocket server URL for real-time position/telemetry streaming
MOTH_SERVER_URL=wss://cobot.center:8287/pang/ws/meb?channel=instant&name=agents&source=base&track=base

# Topic templates for device healthchecks and telemetry
# {track_type} is replaced with actual values; healthcheck uses the shared stream
MOTH_HEALTHCHECK_TOPIC_TEMPLATE=agents
MOTH_TELEMETRY_TOPIC_TEMPLATE=device.telemetry.{device_id}.{track_type}

# ============ Database ============
DATABASE_URL=sqlite:///device_registry.db

# ============ CORS ============
# Comma-separated list of allowed origins (* = allow all)
CORS_ORIGINS=*
