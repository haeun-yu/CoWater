################################################################################
# CoWater Infrastructure Configuration
# All services, LLM backends, agent upstreams, and model selections in one place
################################################################################

# ============================================================================
# 1. 데이터베이스 설정 (PostgreSQL + TimescaleDB)
# ============================================================================
POSTGRES_PASSWORD=<strong_password_here>
POSTGRES_USER=cowater
POSTGRES_DB=cowater
POSTGRES_PORT=5432

# 바인드 주소: 로컬만 접근(127.0.0.1) vs 원격도 접근(0.0.0.0)
POSTGRES_BIND_ADDR=0.0.0.0

# 분산 배포: 원격 PostgreSQL 연결 (설정 시 위 POSTGRES_* 무시)
# DATABASE_URL=postgresql+asyncpg://cowater:password@192.168.1.100:5432/cowater

# ============================================================================
# 2. Redis 설정 (Pub/Sub Event Bus)
# ============================================================================
REDIS_PASSWORD=<strong_password_here>
REDIS_PORT=6379

# 바인드 주소: 로컬만(127.0.0.1) vs 원격도(0.0.0.0)
REDIS_BIND_ADDR=0.0.0.0

# 분산 배포: 원격 Redis 연결 (설정 시 REDIS_PASSWORD 무시)
# REDIS_URL=redis://:password@192.168.1.100:6379

# ============================================================================
# 3. 코어 서비스 바인드 주소
# ============================================================================
CORE_BIND_ADDR=0.0.0.0
CORE_PORT=8000

MOTH_BIND_ADDR=0.0.0.0
MOTH_PORT=8002

# ============================================================================
# 4. LLM 백엔드 설정 (AI 에이전트용)
# ============================================================================
# 선택: claude | ollama | vllm
LLM_BACKEND=claude

# Claude API (권장)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama 로컬 모델 (LLM_BACKEND=ollama일 때)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# vLLM 고성능 서버 (LLM_BACKEND=vllm일 때)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=meta-llama/Llama-2-7b-chat-hf

# ============================================================================
# 5. Agent Gateway Upstream 설정
# ============================================================================
CONTROL_AGENTS_UPSTREAM=http://control-agents:8001
CONTROL_AGENTS_PORT=7701

DETECTION_AGENTS_UPSTREAM=http://detection-agents:8001
DETECTION_AGENTS_PORT=7704

ANALYSIS_AGENTS_UPSTREAM=http://analysis-agents:8001
ANALYSIS_AGENTS_PORT=7705

RESPONSE_AGENTS_UPSTREAM=http://response-agents:8001
RESPONSE_AGENTS_PORT=7706

SUPERVISION_AGENTS_UPSTREAM=http://supervision-agents:8001
SUPERVISION_AGENTS_PORT=7707

LEARNING_AGENTS_UPSTREAM=http://learning-agents:8001
LEARNING_AGENTS_PORT=7708

REPORT_AGENTS_UPSTREAM=http://report-agents:8001
REPORT_AGENTS_PORT=7709

# ============================================================================
# 6. Agent별 LLM 모델 오버라이드 (선택)
# ============================================================================
# CONTROL_AGENT_MODEL=claude-3-5-sonnet-20241022
# ANALYSIS_AGENT_MODEL=claude-3-5-sonnet-20241022
# REPORT_AGENT_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# 7. 로깅 설정
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# 8. 시뮬레이터 설정 (docker compose --profile simulation)
# ============================================================================
SCENARIO=demo
SIMULATION_SPEED=3.0

# ============================================================================
# 9. Moth 서버 설정
# ============================================================================
MOTH_SERVER_URL=wss://cobot.center:8287

# ============================================================================
# 10. Frontend 환경 변수 (services/frontend/.env.local에도 반영)
# ============================================================================
NEXT_PUBLIC_CORE_URL=http://localhost:7700
NEXT_PUBLIC_AGENTS_URL=http://localhost:7701
NEXT_PUBLIC_DETECTION_URL=http://localhost:7704
NEXT_PUBLIC_ANALYSIS_URL=http://localhost:7705
NEXT_PUBLIC_RESPONSE_URL=http://localhost:7706
NEXT_PUBLIC_SUPERVISION_URL=http://localhost:7707
NEXT_PUBLIC_LEARNING_URL=http://localhost:7708
NEXT_PUBLIC_REPORT_URL=http://localhost:7709
NEXT_PUBLIC_WS_URL=ws://localhost:7700
NEXT_PUBLIC_POSITION_WS_URL=ws://localhost:7703
