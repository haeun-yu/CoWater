################################################################################
# CoWater Agent Services Only Configuration
#
# Agent Services만 실행하는 서버용 설정 (분산 배포)
# 예: detection-agents, analysis-agents, control-agents, response-agents 등
#
# 사용법:
#   cp .env.agents-only.example .env.local
#   # 아래의 호스트명/IP를 실제 환경에 맞게 수정
#   docker compose up -d detection-agents analysis-agents
#
# 주의: DATABASE_URL과 REDIS_URL은 중앙 데이터베이스/Redis 서버를 가리켜야 함
################################################################################

# ============================================================================
# 1. 중앙 데이터베이스 연결 (PostgreSQL + TimescaleDB)
# ============================================================================
# 형식: postgresql+asyncpg://user:password@호스트:포트/데이터베이스
# 예: DB가 192.168.1.100에 있는 경우
DATABASE_URL=postgresql+asyncpg://cowater:secure_password@192.168.1.100:5432/cowater

# ============================================================================
# 2. 중앙 Redis 연결 (Pub/Sub Event Bus)
# ============================================================================
# 형식: redis://:password@호스트:포트
# 예: Redis가 192.168.1.100에 있는 경우
REDIS_URL=redis://:secure_password@192.168.1.100:6379

# ============================================================================
# 3. LLM 백엔드 설정 (AI 에이전트용)
# ============================================================================
# 선택: claude | ollama | vllm
LLM_BACKEND=claude

# Claude API (권장)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama 로컬 모델 (LLM_BACKEND=ollama일 때)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# vLLM 고성능 서버 (LLM_BACKEND=vllm일 때)
# VLLM_BASE_URL=http://localhost:8000
# VLLM_MODEL=meta-llama/Llama-2-7b-chat-hf

# ============================================================================
# 4. Agent Gateway Upstream 설정 (로컬 실행, 컨테이너명 사용)
# ============================================================================
# 같은 docker-compose 네트워크 내에서 실행되는 경우, 컨테이너명으로 자동 해석
# 각 에이전트는 :8001에서 내부 수신 (agent-gateway가 :7701-7709으로 리버스 프록시)

CONTROL_AGENTS_UPSTREAM=http://control-agents:8001
CONTROL_AGENTS_PORT=7701

DETECTION_AGENTS_UPSTREAM=http://detection-agents:8001
DETECTION_AGENTS_PORT=7704

ANALYSIS_AGENTS_UPSTREAM=http://analysis-agents:8001
ANALYSIS_AGENTS_PORT=7705

RESPONSE_AGENTS_UPSTREAM=http://response-agents:8001
RESPONSE_AGENTS_PORT=7706

SUPERVISION_AGENTS_UPSTREAM=http://supervision-agents:8001
SUPERVISION_AGENTS_PORT=7707

LEARNING_AGENTS_UPSTREAM=http://learning-agents:8001
LEARNING_AGENTS_PORT=7708

REPORT_AGENTS_UPSTREAM=http://report-agents:8001
REPORT_AGENTS_PORT=7709

# ============================================================================
# 5. Agent별 LLM 모델 오버라이드 (선택)
# ============================================================================
# CONTROL_AGENT_MODEL=claude-3-5-sonnet-20241022
# ANALYSIS_AGENT_MODEL=claude-3-5-sonnet-20241022
# REPORT_AGENT_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# 6. 로깅 설정
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# 7. 참고: 이 서버에서 실행하지 않는 서비스들
# ============================================================================
# postgres, redis, core, moth-bridge, frontend 등은 중앙 서버에서 실행됨
# 따라서 POSTGRES_BIND_ADDR, REDIS_BIND_ADDR, CORE_BIND_ADDR 등은 불필요
