# Swarm/global shared environment

STACK_NAME=cowater
LOG_LEVEL=info

# Shared infrastructure endpoints (private network / overlay / DNS)
DATABASE_URL=postgresql+asyncpg://cowater:change-me@postgres.internal:5432/cowater
REDIS_URL=redis://redis.internal:6379

# Service-to-service endpoints
CORE_API_URL=http://core.internal:8000
AGENTS_API_URL=http://agents.internal:8001
MOTH_SERVER_URL=wss://cobot.center:8287

# LLM routing
LLM_BACKEND=ollama
OLLAMA_URL=http://llm.internal:11434
OLLAMA_MODEL=qwen2.5:3b
CHAT_OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_THINK=false
VLLM_URL=http://vllm.internal:8000
VLLM_MODEL=Qwen/Qwen2.5-3B-Instruct

# Browser-facing endpoints
NEXT_PUBLIC_API_URL=https://core.example.com
NEXT_PUBLIC_WS_URL=wss://core.example.com
NEXT_PUBLIC_AGENTS_URL=https://agents.example.com
NEXT_PUBLIC_POSITION_WS_URL=wss://bridge.example.com
