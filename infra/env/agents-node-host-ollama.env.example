# Agents-only node using host Ollama on the same machine
REDIS_URL=redis://redis.example.internal:6379
CORE_API_URL=http://core.example.internal:8000
LLM_BACKEND=ollama
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:3b
CHAT_OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_THINK=false
LOG_LEVEL=info
