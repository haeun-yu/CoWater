################################################################################
# CoWater Simulator Configuration
#
# 시뮬레이터만 실행하는 서버용 설정 (분산 배포)
# 예: 시뮬레이터가 AIS 데이터를 생성하여 Moth 서버에 퍼블리시
#
# 사용법:
#   cp .env.simulator.example .env.local
#   docker compose --profile simulation up -d simulator
#
# 참고:
#   - MOTH_SERVER_URL: 중앙 서버의 Moth 서버 주소 (또는 로컬)
#   - SCENARIO: 시뮬레이션 시나리오 선택
#   - SIMULATION_SPEED: 시뮬레이션 속도 배수 (기본: 1.0 = 실시간)
#   - 시뮬레이터는 Moth Server를 제외한 다른 서비스(DB, Redis 등)에 직접 연결하지 않음
################################################################################

# ============================================================================
# 1. Moth 서버 설정 (AIS 데이터 퍼블리시 대상)
# ============================================================================
# 로컬: 중앙 서버의 moth-bridge가 Moth Server 역할 (실제 Moth는 외부)
# 원격: 다른 호스트의 Moth 서버 주소

# 로컬 환경 (중앙 서버의 moth-bridge를 통해 실제 Moth에 연결)
# MOTH_SERVER_URL=wss://localhost:8287

# 원격 환경 (실제 Moth 서버)
MOTH_SERVER_URL=wss://cobot.center:8287

# 원격 환경 (다른 호스트의 moth-bridge)
# MOTH_SERVER_URL=wss://192.168.1.100:8287

# ============================================================================
# 2. 시뮬레이터 설정
# ============================================================================
# 시나리오 선택: demo | collision_risk | 기타 (services/simulator/scenarios/ 참조)
SCENARIO=demo

# 시뮬레이션 속도 배수
# 1.0 = 실시간
# 3.0 = 3배속 (기본값)
# 10.0 = 10배속 (빠른 테스트)
SIMULATION_SPEED=3.0

# ============================================================================
# 3. 로깅 설정
# ============================================================================
LOG_LEVEL=info

# ============================================================================
# 4. 참고: 시뮬레이터가 연결하지 않는 서비스들
# ============================================================================
# postgres, redis, core, agent-gateway 등은 필요 없음
# 시뮬레이터는 YAML 시나리오 기반 AIS 메시지를 생성하여
# Moth Server에만 전송 (WebSocket 클라이언트 역할)
