# USV Lower Agent - Configuration Template
# Copy this file to .env or .env.local and customize values

# ============ Server Configuration ============
COWATER_AGENT_PORT=9111

# ============ Registry Configuration ============
COWATER_HEARTBEAT_INTERVAL_SECONDS=10

# ============ Moth Integration ============
COWATER_MOTH_ENABLED=true
COWATER_MOTH_SERVER_URL=wss://cobot.center:8287
COWATER_MOTH_RECONNECT_INTERVAL_SECONDS=5

# ============ LLM Configuration ============
# LLM Provider: "ollama"
COWATER_LLM_PROVIDER=ollama
# Ollama server endpoint
COWATER_LLM_ENDPOINT=http://localhost:11434
# Model name (e.g., gemma4, llama2, mistral)
COWATER_LLM_MODEL=gemma4:e2b
# Enable/Disable LLM for this agent
COWATER_LLM_ENABLED=true
# LLM call timeout in seconds
COWATER_LLM_TIMEOUT_SECONDS=30
