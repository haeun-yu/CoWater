{
  "name": "marine-platform-simulator",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n ui,sim -c cyan,yellow \"npm:dev:ui\" \"npm:dev:simulator\"",
    "start": "npm run dev",
    "dev:ui": "vite --host 0.0.0.0 --port 5005",
    "dev:moth": "tsx server/moth-bridge.ts",
    "dev:simulator": "tsx server/simulator-publisher.ts",
    "build": "tsc --noEmit && vite build",
    "test": "node --import tsx --test src/lib/cpa.test.ts",
    "preview": "vite preview --host 0.0.0.0 --port 7001 --strictPort"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-leaflet": "^5.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.20",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
